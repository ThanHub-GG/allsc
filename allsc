local keyFileName = "thananjay1_key.txt"
local verFileName = "thananjay1_ver.txt"

local function loadScript(version)
    local scriptId = gameConfig.script_ids[version]
    if not scriptId then return false end
    api.script_id = scriptId
    local currentKey = getgenv().script_key or _G.script_key
    if currentKey then
        pcall(function() script_key = currentKey end)
        pcall(function() _G.script_key = currentKey end)
    end
    local ok = pcall(function() api.load_script() end)
    return ok
end

local function checkKeyDirect(key, version)
    if not key or key == "" then return false, {code="KEY_INCORRECT"} end
    local scriptId = gameConfig.script_ids[version]
    if not scriptId then return false, {code="INVALID_VERSION"} end
    api.script_id = scriptId
    local ok, result = pcall(function() api.check_key(key) end)
    if ok then
        return true, "KEY_VALID"
    else
        local e = tostring(result or ""):upper()
        local code = "KEY_INCORRECT"
        if e:find("HWID") then code = "KEY_HWID_LOCKED"
        elseif e:find("EXPIRE") then code = "KEY_EXPIRED"
        elseif e:find("BAN") then code = "KEY_BANNED" end
        return false, {code=code, message=result}
    end
end

local function deleteSavedFiles()
    if isfile and delfile then
        pcall(function()
            if isfile(keyFileName) then delfile(keyFileName) end
            if isfile(verFileName)  then delfile(verFileName)  end
        end)
    end
end

local function checkSavedKey()
    if not (isfile and readfile) then return false end
    local savedKey, savedVer = nil, "normal"
    pcall(function()
        if isfile(keyFileName) and isfile(verFileName) then
            local k = readfile(keyFileName)
            local v = readfile(verFileName)
            if k and k ~= "" then savedKey = k:gsub("%s+","") end
            if v and v ~= "" then savedVer = v:gsub("%s+",""):lower() end
        end
    end)
    if not savedKey or savedKey == "" then return false end
    local valid = checkKeyDirect(savedKey, savedVer)
    if valid then
        getgenv().script_key   = savedKey
        getgenv().HoN_Version  = savedVer
        StarterGui:SetCore("SendNotification", {
            Title    = "Auto-Login!";
            Text     = gameConfig.name .. " | " .. savedVer:upper();
            Icon     = Config.LogoAssetId;
            Duration = 3;
        })
        loadScript(savedVer)
        return true
    else
        deleteSavedFiles()
    end
    return false
end

if checkSavedKey() then return end

-- ============================================================
--  PROTECT GUI  (versi kuat: metatable + loop + ancestry)
-- ============================================================
local function protectGUI(gui)
    -- Pastikan parent benar saat ancestry berubah
    gui.AncestryChanged:Connect(function(_, parent)
        if parent ~= CoreGui then
            task.defer(function()
                pcall(function() gui.Parent = CoreGui end)
            end)
        end
    end)

    -- Cegah child penting terhapus (frame utama)
    gui.DescendantRemoving:Connect(function(desc)
        -- Jika yang dihapus adalah ScreenGui itu sendiri, kembalikan
        if desc == gui then
            task.defer(function()
                pcall(function() gui.Parent = CoreGui end)
            end)
        end
    end)

    -- Loop pengaman setiap 1 detik
    task.spawn(function()
        while true do
            task.wait(1)
            -- Cek apakah GUI masih ada dan parent-nya benar
            local ok = pcall(function()
                if gui.Parent ~= CoreGui then
                    gui.Parent = CoreGui
                end
            end)
            -- Jika GUI sudah benar-benar hancur (pcall gagal), berhenti
            if not ok then break end
        end
    end)

    -- Proteksi tambahan via __newindex metatable pada instance
    -- (memblokir upaya mengubah .Parent dari luar lewat script lain)
    pcall(function()
        local mt = {
            __newindex = function(_, key, value)
                if key == "Parent" and value ~= CoreGui then
                    -- abaikan / paksa kembali ke CoreGui
                    task.defer(function()
                        pcall(function() gui.Parent = CoreGui end)
                    end)
                    return
                end
                rawset(_, key, value)
            end
        }
        -- Hanya executor tertentu yang mendukung setrawmetatable
        if setrawmetatable then
            setrawmetatable(gui, mt)
        end
    end)
end

