local function loadScript(version)
    local scriptId = gameConfig.script_ids[version]
    if not scriptId then return false end

    warn("LOADING VERSION:", version:upper())
    api.script_id = scriptId

    local currentKey = getgenv().script_key or _G.script_key
    if currentKey then
        pcall(function() script_key = currentKey end)
        pcall(function() _G.script_key = currentKey end)
    end

    local ok, err = pcall(function()
        api.load_script()
    end)
    return ok
end

local function checkKeyDirect(key, version)
    if not key or key == "" then return false, {code = "KEY_INCORRECT", message = "Empty key"} end
    
    local scriptId = gameConfig.script_ids[version]
    if not scriptId then return false, {code = "INVALID_VERSION", message = "No script ID"} end
    
    api.script_id = scriptId
    
    local ok, result = pcall(function()
        api.check_key(key)
    end)

    if ok then
        return true, "KEY_VALID"
    else
        local errMsg = tostring(result or "KEY_INCORRECT"):upper()
        local finalCode = "KEY_INCORRECT"
        if string.find(errMsg, "HWID") then finalCode = "KEY_HWID_LOCKED"
        elseif string.find(errMsg, "EXPIRE") then finalCode = "KEY_EXPIRED"
        elseif string.find(errMsg, "BAN") then finalCode = "KEY_BANNED" end
        return false, {code = finalCode, message = result}
    end
end

local keyFileName = "thananjay1_key.txt"
local versionFileName = "thananjay1_ver.txt"

local function checkSavedKey()
    local savedKey = nil
    local savedVer = "normal"

    if isfile and readfile then
        pcall(function()
            if isfile(keyFileName) and isfile(versionFileName) then
                local contentKey = readfile(keyFileName)
                local contentVer = readfile(versionFileName)
                if contentKey and contentKey ~= "" then savedKey = contentKey:gsub("%s+", "") end
                if contentVer and contentVer ~= "" then savedVer = contentVer:gsub("%s+", ""):lower() end
            end
        end)
    end

    if not savedKey or savedKey == "" then return false end

    local valid, result = checkKeyDirect(savedKey, savedVer)
    if valid then
        getgenv().script_key = savedKey
        getgenv().HoN_Version = savedVer
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Key Auto-Logged!";
            Text = gameConfig.name .. " | " .. savedVer:upper();
            Icon = "rbxassetid://85779221265543";
            Duration = 3;
        })
        loadScript(savedVer)
        return true
    else
        if isfile and delfile then
            pcall(function()
                if isfile(keyFileName) then delfile(keyFileName) end
                if isfile(versionFileName) then delfile(versionFileName) end
            end)
        end
    end
    return false
end

if checkSavedKey() then return end

