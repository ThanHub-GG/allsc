local isVerifying = false
local function VerifyKey()
    if isVerifying then return end

    local key = KeyInput.Text:gsub("%s+", "")
    if key == "" then
        Description.Text = "Please enter a key!"
        Description.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end

    isVerifying = true
    local targetVersion = selectedVersionUI -- Ambil versi dari TAB UI
    Description.Text = "Checking " .. targetVersion:upper() .. " key..."
    Description.TextColor3 = Color3.fromRGB(255, 200, 100)
    SubmitBtnText.Text = "Verifying..."

    task.spawn(function()
        -- 1. Cek validitas key ke server Aegis dulu
        local valid, result = checkKeyDirect(key, targetVersion)

        if valid then
            Description.Text = "Key valid! Launching script..."
            Description.TextColor3 = Color3.fromRGB(100, 255, 150)

            getgenv().script_key = key
            getgenv().HoN_Version = targetVersion
            pcall(function() _G.script_key = key end)

            local isScriptLoaded = loadScript(targetVersion)

            if isScriptLoaded then
                if writefile then
                    pcall(function() 
                        writefile(keyFileName, key) 
                        writefile(versionFileName, targetVersion)
                    end)
                end
                
                KeySystemUI:Destroy()
            else
                getgenv().script_key = nil
                getgenv().HoN_Version = nil
                pcall(function() _G.script_key = nil end)

                Description.Text = "Failed to load script game! Try again."
                Description.TextColor3 = Color3.fromRGB(255, 100, 100)
                SubmitBtnText.Text = "Verify Key"
                isVerifying = false
            end
        else
            getgenv().script_key = nil
            getgenv().HoN_Version = nil
            pcall(function() _G.script_key = nil end)
            
            if isfile and delfile then
                pcall(function()
                    if isfile(keyFileName) then delfile(keyFileName) end
                    if isfile(versionFileName) then delfile(versionFileName) end
                end)
            end

            local statusMessages = {
                KEY_HWID_LOCKED = "Key locked to another HWID",
                KEY_INCORRECT   = "Invalid key for " .. targetVersion:upper() .. " version",
                KEY_EXPIRED     = "Key expired, please get a new key",  -- lebih jelas
                KEY_BANNED      = "Key banned"
            }
            
            Description.Text = statusMessages[result.code] or "Verification failed"
            Description.TextColor3 = Color3.fromRGB(255, 100, 100)
            SubmitBtnText.Text = "Verify Key"
            
            KeyInput.Text = ""
            isVerifying = false
        end
    end)
end

