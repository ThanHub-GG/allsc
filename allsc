--  VERIFY LOGIC
-- ============================================================
local isVerifying = false

local function setStatus(text, color)
    StatusLabel.Text = text
    StatusLabel.TextColor3 = color or C.TEXT_MUTED
end

local function VerifyKey()
    if isVerifying then return end
    local key = KeyInput.Text:gsub("%s+", "")
    if key == "" then
        setStatus("⚠  Key tidak boleh kosong!", C.ERROR)
        return
    end

    isVerifying = true
    local targetVersion = selectedVersionUI
    setStatus("🔄  Mengecek key " .. targetVersion:upper() .. "...", C.WARN)
    SubmitLabel.Text = "  Memverifikasi..."

    task.spawn(function()
        api.script_id = gameConfig.script_ids[targetVersion]

        local ok, status = pcall(function() return api.check_key(key) end)

        if ok and status then
            if status.code == "KEY_VALID" then
                -- Hitung sisa waktu
                local hours_left
                if status.data.auth_expire == 0 then
                    hours_left = "Permanent"
                else
                    local sisa = status.data.auth_expire - os.time()
                    if sisa > 0 then
                        local hari = math.floor(sisa / 86400)
                        local jam  = math.floor((sisa % 86400) / 3600)
                        hours_left = hari .. "h " .. jam .. "j"
                    else
                        deleteSavedFiles()
                        getgenv().script_key  = nil
                        getgenv().HoN_Version = nil
                        setStatus("❌  Key sudah expired!", C.ERROR)
                        SubmitLabel.Text = "  Verify Key"
                        isVerifying = false
                        return
                    end
                end

                setStatus("✅  Key valid! (" .. hours_left .. " tersisa)", C.SUCCESS)
                getgenv().script_key  = key
                getgenv().HoN_Version = targetVersion
                pcall(function() _G.script_key = key end)

                if writefile then
                    pcall(function()
                        writefile(keyFileName, key)
                        writefile(verFileName,  targetVersion)
                    end)
                end

                task.wait(0.8)
                local loaded = loadScript(targetVersion)
                if loaded then
                    -- Animasi close
                    tw(Base, 0.35, {Size = UDim2.fromOffset(0, 0), BackgroundTransparency = 1}):Play()
                    task.delay(0.35, function()
                        pcall(function() blur:Destroy() end)
                        KeySystemUI:Destroy()
                    end)
                else
                    setStatus("❌  Gagal memuat script!", C.ERROR)
                    SubmitLabel.Text = "  Verify Key"
                    isVerifying = false
                end

            elseif status.code == "KEY_EXPIRED" then
                deleteSavedFiles()
                getgenv().script_key  = nil
                getgenv().HoN_Version = nil
                setStatus("❌  Key expired & file dihapus!", C.ERROR)
                SubmitLabel.Text = "  Verify Key"
                isVerifying = false

            elseif status.code == "KEY_HWID_LOCKED" then
                setStatus("🔒  Key terkunci di perangkat lain!", C.ERROR)
                SubmitLabel.Text = "  Verify Key"
                isVerifying = false

            elseif status.code == "KEY_BANNED" then
                setStatus("🚫  Key di-banned!", C.ERROR)
                SubmitLabel.Text = "  Verify Key"
                isVerifying = false

            else
                setStatus("❌  Key status: " .. tostring(status.code), C.ERROR)
                SubmitLabel.Text = "  Verify Key"
                isVerifying = false
            end
        else
            setStatus("❌  Key tidak valid atau gagal cek.", C.ERROR)
            SubmitLabel.Text = "  Verify Key"
            isVerifying = false
        end
    end)
end

SubmitBtn.MouseButton1Click:Connect(VerifyKey)
KeyInput.FocusLost:Connect(function(ep) if ep then VerifyKey() end end)

